{
  "name": "my-project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "phone": "expo start --lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "npx expo export:web",
    "build:preview": "npx eas build --platform android --profile preview",
    "build:production": "npx eas build --platform android --profile production",
    "update:preview:direct": "npx eas update --channel preview --platform android --message \"Preview OTA update\"",
    "update:production": "npx eas update --channel production --platform android --message \"Production OTA update\"",
    "sql:run": "node scripts/snowflake-sql-cli.js",
    "sql:test": "node scripts/snowflake-sql-cli.js --sql \"SELECT CURRENT_USER(), CURRENT_ROLE(), CURRENT_WAREHOUSE(), CURRENT_DATABASE(), CURRENT_SCHEMA(), TO_VARCHAR(CURRENT_TIMESTAMP(), 'YYYY-MM-DD HH24:MI:SS TZHTZM')\"",
    "export:preview": "npx expo export --output-dir dist --platform android --dump-assetmap",
    "publish:preview": "npx eas update --channel preview --platform android --skip-bundler --input-dir dist --non-interactive --message \"Preview OTA update\"",
    "update:preview": "npm run export:preview && npm run publish:preview",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.13",
    "@expo/webpack-config": "^0.17.2",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.9.12",
    "@react-navigation/stack": "^6.3.16",
    "@types/react-native-elements": "^0.18.0",
    "base-64": "^1.0.0",
    "expo": "^47.0.0",
    "expo-application": "~5.0.1",
    "expo-device": "~5.0.0",
    "expo-local-authentication": "~13.0.2",
    "expo-location": "~15.0.1",
    "expo-secure-store": "~12.0.0",
    "expo-status-bar": "~1.4.2",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.3.3",
    "react": "18.1.0",
    "react-dom": "18.1.0",
    "react-native": "0.70.8",
    "react-native-dotenv": "^3.4.8",
    "react-native-elements": "^3.4.3",
    "react-native-gesture-handler": "~2.8.0",
    "react-native-maps": "1.3.2",
    "react-native-pager-view": "6.0.1",
    "react-native-rsa-native": "^2.0.5",
    "react-native-safe-area-context": "4.4.1",
    "react-native-screens": "~3.18.0",
    "react-native-spinner-button": "^1.4.0",
    "react-native-tab-view": "^3.5.1",
    "react-native-uuid": "^2.0.3",
    "react-native-web": "~0.18.9",
    "react-navigation": "^4.4.4",
    "expo-build-properties": "~0.4.1",
    "expo-updates": "~0.15.6",
    "@expo/ngrok": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "patch-package": "^8.0.1",
    "react-native-reanimated": "^2.14.4",
    "rn-nodeify": "github:tradle/rn-nodeify"
  },
  "expo": {
    "autolinking": {
      "include": [
        "expo-file-system"
      ]
    }
  },
  "private": true
}